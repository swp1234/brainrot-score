    "p8": { "user": "\u0421\u043b\u044d\u0439 \u043a\u0432\u0438\u043d", "text": "\u0423 \u043c\u0435\u043d\u044f 47 \u0432\u043a\u043b\u0430\u0434\u043e\u043a \u0432 \u0431\u0440\u0430\u0443\u0437\u0435\u0440\u0435 \u0442\u0435\u043b\u0435\u0444\u043e\u043d\u0430. \u041a\u0430\u0436\u0434\u0430\u044f \u2014 \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u0430\u044f \u043b\u0438\u0447\u043d\u043e\u0441\u0442\u044c." },
    "p9": { "user": "\u041f\u0438\u0442\u043e\u043c\u0435\u0446 \u0430\u043b\u0433\u043e\u0440\u0438\u0442\u043c\u0430", "text": "\u042f \u0432 3 \u043d\u043e\u0447\u0438 \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u044e \u0440\u0435\u0448\u0435\u043d\u0438\u044f \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u0442\u0438\u043a\u0442\u043e\u043a\u0430, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0432\u0438\u0434\u0435\u043b 2 \u0441\u0435\u043a\u0443\u043d\u0434\u044b \u043d\u0430\u0437\u0430\u0434" },
