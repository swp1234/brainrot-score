    "p11": { "user": "\u0421\u043a\u0438\u0431\u0438\u0434\u0438 \u0441\u0442\u0430\u043d", "text": "\u0421\u043a\u0438\u0431\u0438\u0434\u0438 \u0434\u043e\u043f \u0434\u043e\u043f \u0434\u043e\u043f \u0435\u0441 \u0435\u0441. \u0415\u0441\u043b\u0438 \u043f\u043e\u043d\u044f\u043b \u2014 \u043d\u0430\u043c \u043d\u0430\u0434\u043e \u043f\u043e\u0433\u043e\u0432\u043e\u0440\u0438\u0442\u044c." },
    "p12": { "user": "\u0413\u043b\u0430\u0432\u043d\u044b\u0439 \u0433\u0435\u0440\u043e\u0439", "text": "\u042f \u043a\u043e\u043c\u043c\u0435\u043d\u0442\u0438\u0440\u0443\u044e \u0441\u0432\u043e\u044e \u0436\u0438\u0437\u043d\u044c \u0432 \u0433\u043e\u043b\u043e\u0432\u0435 \u043a\u0430\u043a \u0442\u0438\u043a\u0442\u043e\u043a-\u043e\u0437\u0432\u0443\u0447\u043a\u0443. \u0414\u0435\u043b\u044e\u0437\u0438\u044f \u0440\u0435\u0430\u043b\u044c\u043d\u0430." },
