    "p3": { "user": "\u0414\u0443\u043c-\u0441\u043a\u0440\u043e\u043b\u043b\u0435\u0440", "text": "\u0423 \u043c\u0435\u043d\u044f \u043d\u0435\u0442 \u0440\u0430\u0441\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u0441\u043d\u0430, \u0443 \u043c\u0435\u043d\u044f \u0435\u0441\u0442\u044c \u0440\u0430\u0441\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u00ab\u0432\u044b\u0440\u0443\u0431\u0438\u0442\u044c\u0441\u044f \u043e\u0442 \u0443\u0441\u0442\u0430\u043b\u043e\u0441\u0442\u0438\u00bb" },
    "p4": { "user": "\u041d\u0435 \u0442\u0440\u043e\u0433\u0430\u044e \u0442\u0440\u0430\u0432\u0443", "text": "\u0410\u043b\u0433\u043e\u0440\u0438\u0442\u043c \u0437\u043d\u0430\u0435\u0442 \u043c\u0435\u043d\u044f \u043b\u0443\u0447\u0448\u0435 \u043f\u0441\u0438\u0445\u043e\u043b\u043e\u0433\u0430 \u0438 \u0441\u0442\u043e\u0438\u0442 0 \u0440\u0443\u0431/\u043c\u0435\u0441" },
    "p5": { "user": "\u0421\u0438\u0433\u043c\u0430 \u0441\u0442\u0430\u043d", "text": "\u0415\u0441\u043b\u0438 \u0431\u044b \u043c\u043d\u0435 \u043f\u043b\u0430\u0442\u0438\u043b\u0438 \u0437\u0430 \u043a\u0430\u0436\u0434\u044b\u0439 \u0447\u0430\u0441 \u044d\u043a\u0440\u0430\u043d\u043d\u043e\u0433\u043e \u0432\u0440\u0435\u043c\u0435\u043d\u0438, \u044f \u0431\u044b \u0443\u0436\u0435 \u043d\u0430 \u043f\u0435\u043d\u0441\u0438\u0438 \u0432 25" },
    "p6": { "user": "\u0425\u0440\u043e\u043d\u0438\u0447\u0435\u0441\u043a\u0438 \u043e\u043d\u043b\u0430\u0439\u043d", "text": "\u0421\u043b\u0443\u0447\u0430\u0439\u043d\u043e \u0441\u043a\u0430\u0437\u0430\u043b \u0431\u0430\u0431\u0443\u0448\u043a\u0435 \u00ab\u0436\u0438\u0437\u0430\u00bb \u0437\u0430 \u0443\u0436\u0438\u043d\u043e\u043c. \u041e\u043d\u0430 \u0441\u043f\u0440\u043e\u0441\u0438\u043b\u0430 \u00ab\u0447\u0442\u043e \u0437\u0430 \u0436\u0438\u0437\u0430?\u00bb" },
