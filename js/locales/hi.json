  "posts": {
    "p1": { "user": "\u092c\u094d\u0930\u0947\u0928\u0930\u0949\u091f \u0915\u093f\u0902\u0917", "text": "POV: '\u092c\u0938 5 \u092e\u093f\u0928\u091f' \u0915\u0947 \u0932\u093f\u090f \u0910\u092a \u0916\u094b\u0932\u093e \u0914\u0930 3 \u0918\u0902\u091f\u0947 \u092c\u0940\u0924 \u0917\u090f" },
    "p2": { "user": "\u092e\u0940\u092e \u0921\u0940\u0932\u0930", "text": "\u092e\u0947\u0930\u0947 \u0938\u094d\u0915\u094d\u0930\u0940\u0928\u091f\u093e\u0907\u092e \u0930\u093f\u092a\u094b\u0930\u094d\u091f \u0928\u0947 \u092e\u0941\u091d\u0947 \u0935\u0947\u0932\u0928\u0947\u0938 \u091a\u0947\u0915 \u0928\u094b\u091f\u093f\u092b\u093f\u0915\u0947\u0936\u0928 \u092d\u0947\u091c\u093e" },
    "p3": { "user": "\u0921\u0942\u092e\u0938\u094d\u0915\u094d\u0930\u094b\u0932\u0930", "text": "\u092e\u0947\u0930\u093e \u0938\u094b\u0928\u0947 \u0915\u093e \u0936\u0947\u0921\u094d\u092f\u0942\u0932 \u0928\u0939\u0940\u0902, '\u0925\u0915\u093e\u0935\u091f \u0938\u0947 \u092c\u0947\u0939\u094b\u0936' \u0936\u0947\u0921\u094d\u092f\u0942\u0932 \u0939\u0948" },
    "p4": { "user": "\u0918\u093e\u0938 \u0928\u0939\u0940\u0902 \u091b\u0942\u0928\u093e", "text": "\u090f\u0932\u094d\u0917\u094b\u0930\u093f\u0926\u092e \u092e\u0947\u0930\u0947 \u0925\u0947\u0930\u0947\u092a\u093f\u0938\u094d\u091f \u0938\u0947 \u091c\u094d\u092f\u093e\u0926\u093e \u092e\u0941\u091d\u0947 \u0938\u092e\u091d\u0924\u093e \u0939\u0948 \u0914\u0930 \u092e\u0939\u0940\u0928\u093e 0 \u0930\u0941\u092a\u092f\u0947" },
    "p5": { "user": "\u0938\u093f\u0917\u094d\u092e\u093e \u0938\u094d\u091f\u0948\u0928", "text": "\u0905\u0917\u0930 \u0938\u094d\u0915\u094d\u0930\u0940\u0928\u091f\u093e\u0907\u092e \u0915\u0947 \u0939\u0930 \u0918\u0902\u091f\u0947 \u092a\u0930 1 \u0921\u0949\u0932\u0930 \u092e\u093f\u0932\u0924\u093e \u0924\u094b 25 \u092a\u0930 \u0930\u093f\u091f\u093e\u092f\u0930 \u0939\u094b \u091c\u093e\u0924\u093e" },
