    "p9": { "user": "\u090f\u0932\u094d\u0917\u094b\u0930\u093f\u0926\u092e \u0915\u093e \u092a\u0947\u091f", "text": "\u0930\u093e\u0924 3 \u092c\u091c\u0947 2 \u0938\u0947\u0915\u0902\u0921 \u092a\u0939\u0932\u0947 \u0926\u0947\u0916\u0940 \u0930\u0940\u0932 \u0915\u0947 \u0906\u0927\u093e\u0930 \u092a\u0930 \u0932\u093e\u0907\u092b \u0921\u093f\u0938\u0940\u091c\u0928 \u0932\u0947 \u0930\u0939\u093e \u0939\u0942\u0902" },
