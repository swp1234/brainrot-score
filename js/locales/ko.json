  "posts": {
    "p1": { "user": "\ube0c\ub808\uc778\ub86f \ud0b9", "text": "\uc2dc\uc810: '5\ubd84\ub9cc' \ubcf4\ub824\uace0 \uc571 \uc5f4\uc5c8\ub2e4\uac00 3\uc2dc\uac04\uc774 \uc9c0\ub09c \ub098" },
    "p2": { "user": "\ubc08 \ub51c\ub7ec", "text": "\uc2a4\ud06c\ub9b0\ud0c0\uc784 \ub9ac\ud3ec\ud2b8\uac00 \uc548\ubd80 \uba54\uc2dc\uc9c0\ub97c \ubcf4\ub0c8\uc74c" },
    "p3": { "user": "\ub458\uc2a4\ud06c\ub864\ub7ec", "text": "\uc218\uba74 \uc2a4\ucf00\uc904\uc774 \uc544\ub2c8\ub77c '\uae30\uc808\ud574\uc11c \uae30\uc808\ud558\ub294' \uc2a4\ucf00\uc904\uc774 \uc788\uc74c" },
    "p4": { "user": "\ud480\uc548\ub9cc\uc838", "text": "\uc54c\uace0\ub9ac\uc998\uc774 \uc0c1\ub2f4\uc0ac\ubcf4\ub2e4 \ub098\ub97c \ub354 \uc798 \uc54c\uace0 \uc6d4 0\uc6d0\uc784" },
    "p5": { "user": "\uc2dc\uadf8\ub9c8 \uc2a4\ud0e0", "text": "\uc2a4\ud06c\ub9b0\ud0c0\uc784 1\uc2dc\uac04\ub2f9 1\ub9cc\uc6d0\uc774\uba74 \ub098 25\uc0b4\uc5d0 \uc740\ud1f4\ud568" },
    "p6": { "user": "\ub9cc\uc131\uc628\ub77c\uc774\ub108", "text": "\ud560\uba38\ub2c8\ud55c\ud14c \uc2e4\uc218\ub85c 'ㄹㅇ' \ub77c\uace0 \ud588\ub354\ub2c8 '\ubb50\uac00 \uc9c4\uc9dc\ub77c\ub294 \uac70\ub2c8' \ud558\uc168\uc74c" },
    "p7": { "user": "\ub178\ucea1 Fr", "text": "\uc9d1\uc911\ub825\uc774 \ub108\ubb34 \ub9dd\uac00\uc838\uc11c \uc774 \uae00\ub3c4 \uc774\ubbf8 \ub108\ubb34 \uae38\uac8c \ub290\uaef4\uc9c0\ub294 \uc911" },
    "p8": { "user": "\uc2ac\ub808\uc774 \ud018", "text": "\ud578\ub4dc\ud3f0 \ube0c\ub77c\uc6b0\uc800\uc5d0 \ud0ed 47\uac1c \uc5f4\ub824\uc788\uc74c. \uac01\uac01 \ub2e4\ub978 \uc778\uaca9\uc784." },
    "p9": { "user": "\uc54c\uace0\ub9ac\uc998\uc758 \uc560\uc644\uacac", "text": "\uc0c8\ubcbd 3\uc2dc\uc5d0 2\ucd08 \uc804\uc5d0 \ubcf8 \ud2f1\ud1a1 \uae30\ubc18\uc73c\ub85c \uc778\uc0dd \uacb0\uc815 \ub0b4\ub9ac\ub294 \uc911" },
    "p10": { "user": "\uc57c\uac04 \uc804\uc0ac", "text": "\ub208\uc774 \ud0c0\ub294\ub370 \ud53c\ub4dc\uac00 \ubd88\uc774\ub77c \ub9d0 \uadf8\ub300\ub85c \uba48\ucd9c \uc218\uac00 \uc5c6\uc74c" },
    "p11": { "user": "\uc2a4\ud0a4\ube44\ub514 \uc2a4\ud0e0", "text": "\uc2a4\ud0a4\ube44\ub514 \ub601 \ub601 \ub601 \uc608\uc2a4 \uc608\uc2a4. \uc774\uac78 \uc774\ud574\ud588\ub2e4\uba74 \uc6b0\ub9ac \uc598\uae30 \uc880 \ud574\uc57c \ud568." },
    "p12": { "user": "\uc8fc\uc778\uacf5", "text": "\uc778\uc0dd\uc744 \ud2f1\ud1a1 \ub0b4\ub808\uc774\uc158\ucc98\ub7fc \uba38\ub9bf\uc18d\uc73c\ub85c \ub0b4\ub808\uc774\uc158 \uc911. \ub9dd\uc0c1\uc774 \ub9ac\uc5bc." },
    "p13": { "user": "NPC \ud589\ub3d9", "text": "\ub204\uad70\uac00 \ud604\uc2e4\uc5d0\uc11c \ub9d0 \uac78\uc5c8\ub294\ub370 \uc5bc\uad74\uc5d0 \uc2a4\ud0b5 \ubc84\ud2bc \ub204\ub97c \ubfd0\ud588\uc74c" },
    "p14": { "user": "\ub514\ub8f0\ub8e8 \ud018", "text": "\ub108\ubb34 \uc624\ub798 \uc2a4\ud06c\ub864\ud574\uc11c \uc5c4\uc9c0\uac00 \ub3c5\uc790\uc801\uc778 \uc758\uc2dd\uc744 \ubc1c\ub2ec\uc2dc\ud0b4" },
    "p15": { "user": "\uc5b8\ud78c\uc9c0\ub4dc \ud3ec\uc2a4\ud130", "text": "\ub9c8\uc9c0\ub9c9 \uae00\uc785\ub2c8\ub2e4. \uc5ec\uae30\uae4c\uc9c0 \uc77d\uc5c8\ub2e4\uba74 \ucd95\ud558\ud569\ub2c8\ub2e4: \ub2f9\uc2e0\uc758 \ub1cc\ub294 \uacf5\uc2dd\uc801\uc73c\ub85c \ube0c\ub808\uc778\ub86f\ub428." }
